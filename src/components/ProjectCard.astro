---
interface Props {
  slug: string;
  title: string;
  subtitle: string;
  tags: string[];
  status?: string;
  thumb?: string;
  thumbBg: string;
  thumbText?: string;
  thumbTextColor: string;
  metrics: string[];
  cta: string;
}
const { slug, title, subtitle, tags, status, thumb, thumbBg, thumbText, thumbTextColor, metrics, cta } = Astro.props;
---
<a href={`/work/${slug}`} class="card">
  <div class="thumb" style={`background:${thumbBg}`}>
    {thumb
      ? <img src={thumb} alt={title} />
      : <span style={`font-family:var(--font-mono);font-size:12px;color:${thumbTextColor}`}>{thumbText}</span>}
  </div>
  <div class="body">
    <div class="tags">
      {tags.map(t => <span class="tag">{t}</span>)}
      {status && <span class="tag tag-accent">{status}</span>}
    </div>
    <div class="title">{title}</div>
    <div class="subtitle">{subtitle}</div>
    {metrics.length > 0 && (
      <ul class="metrics">
        {metrics.map(m => (
          <li><span class="plus">+</span>{m}</li>
        ))}
      </ul>
    )}
    <span class="cta">{cta} →</span>
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-md);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }
  .thumb {
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .thumb img {
    width: 85%;
    height: 85%;
    object-fit: contain;
    display: block;
  }
  .body { padding: 20px 22px; }
  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .title {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin-bottom: 4px;
  }
  .subtitle {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: var(--fg-muted);
    margin-bottom: 10px;
  }
  .metrics {
    list-style: none;
    padding: 0;
    margin-bottom: 12px;
  }
  .metrics li {
    font-size: 12px;
    color: var(--fg-muted);
    line-height: 1.6;
    display: flex;
    align-items: flex-start;
    gap: 6px;
  }
  .plus { color: var(--accent); font-weight: 600; }
  .cta {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
  }
</style>
