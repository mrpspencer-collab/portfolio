---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---
<Base>
  <Nav />
  <main>
    <section class="hero">
      <canvas id="hero-canvas" aria-hidden="true"></canvas>
      <p class="overline">UX Design · Research · Leadership</p>
      <h1>Product design for data, AI, and complex systems.</h1>
      <div class="actions">
        <a href="#" class="btn btn-primary btn-lg">Download Resume</a>
        <a href="#" class="btn btn-outline btn-lg">Connect on LinkedIn</a>
      </div>
    </section>

    <div class="divider-wrap"><div class="divider"></div></div>

    <section class="work">
      <p class="overline">Selected Work</p>
      <div class="grid">
        {projects.map(p => (
          <ProjectCard
            slug={p.slug}
            title={p.data.title}
            subtitle={p.data.subtitle}
            tags={p.data.tags}
            status={p.data.status}
            thumb={p.data.thumb}
            thumbBg={p.data.thumbBg}
            thumbText={p.data.thumbText}
            thumbTextColor={p.data.thumbTextColor}
            metrics={p.data.metrics}
            cta={p.data.cta}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  main { padding-top: 64px; }

  .hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 96px 40px 80px;
    position: relative;
    overflow: hidden;
  }
  #hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
  .hero > :not(canvas) {
    position: relative;
    z-index: 1;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(24px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--fg);
    max-width: 700px;
    margin: 20px 0 28px;
  }
  .lead {
    font-size: 18px;
    line-height: 1.65;
    color: var(--fg-muted);
    max-width: 540px;
    margin-bottom: 36px;
  }
  .actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .divider-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .divider { height: 1px; background: var(--border); }

  .work {
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 40px 96px;
  }
  .work .overline { margin-bottom: 32px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  @media (max-width: 640px) {
    .hero { padding: 64px 20px 48px; }
    .divider-wrap { padding: 0 20px; }
    .work { padding: 48px 20px 64px; }
    .lead { font-size: 16px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const NODES = 28;
  const CONN_DIST = 160;
  const PACKET_SPEED = 0.004;
  const MOUSE_RADIUS = 200;
  const MOUSE_STRENGTH = 0.012;
  const VEL_MAX_IDLE = 0.3;
  const VEL_MAX_ACTIVE = 1.8;

  type Node = { x: number; y: number; vx: number; vy: number };
  type Packet = { a: number; b: number; t: number };

  const nodes: Node[] = [];
  const packets: Packet[] = [];
  const mouse = { x: -9999, y: -9999, active: false };

  function resize() {
    const r = canvas.parentElement!.getBoundingClientRect();
    canvas.width = r.width;
    canvas.height = r.height;
    nodes.length = 0;
    const leftBound = canvas.width * 0.4;
    for (let i = 0; i < NODES; i++) {
      nodes.push({
        x: leftBound + Math.random() * (canvas.width - leftBound),
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.25,
        vy: (Math.random() - 0.5) * 0.25,
      });
    }
  }

  const hero = canvas.parentElement!;
  hero.addEventListener('mousemove', (e: MouseEvent) => {
    const r = canvas.getBoundingClientRect();
    mouse.x = e.clientX - r.left;
    mouse.y = e.clientY - r.top;
    mouse.active = true;
  });
  hero.addEventListener('mouseleave', () => { mouse.active = false; });

  function spawnPackets() {
    if (packets.length > 12) return;
    for (let i = 0; i < NODES; i++) {
      for (let j = i + 1; j < NODES; j++) {
        const dx = nodes[j].x - nodes[i].x;
        const dy = nodes[j].y - nodes[i].y;
        if (Math.sqrt(dx*dx + dy*dy) < CONN_DIST && Math.random() < 0.003) {
          packets.push({ a: i, b: j, t: 0 });
        }
      }
    }
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const dark = document.documentElement.getAttribute('data-theme') === 'dark';
    const leftBound = canvas.width * 0.38;
    const velMax = mouse.active ? VEL_MAX_ACTIVE : VEL_MAX_IDLE;

    // Move nodes
    nodes.forEach(n => {
      // Mouse attraction
      if (mouse.active) {
        const dx = mouse.x - n.x;
        const dy = mouse.y - n.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < MOUSE_RADIUS && dist > 1) {
          const force = (1 - dist / MOUSE_RADIUS) * MOUSE_STRENGTH;
          n.vx += (dx / dist) * force;
          n.vy += (dy / dist) * force;
        }
      }

      // Clamp velocity
      const speed = Math.sqrt(n.vx * n.vx + n.vy * n.vy);
      if (speed > velMax) { n.vx = (n.vx / speed) * velMax; n.vy = (n.vy / speed) * velMax; }

      n.x += n.vx; n.y += n.vy;

      // Boundaries — left wall at 38%, right/top/bottom at canvas edges
      if (n.x < leftBound) { n.x = leftBound; n.vx = Math.abs(n.vx); }
      if (n.x > canvas.width)  { n.x = canvas.width;  n.vx *= -1; }
      if (n.y < 0)             { n.y = 0;              n.vy = Math.abs(n.vy); }
      if (n.y > canvas.height) { n.y = canvas.height;  n.vy *= -1; }
    });

    // Connections
    for (let i = 0; i < NODES; i++) {
      for (let j = i + 1; j < NODES; j++) {
        const dx = nodes[j].x - nodes[i].x;
        const dy = nodes[j].y - nodes[i].y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < CONN_DIST) {
          const a = (1 - dist / CONN_DIST) * (dark ? 0.07 : 0.06);
          ctx.strokeStyle = dark ? `rgba(255,255,255,${a})` : `rgba(0,0,0,${a})`;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.stroke();
        }
      }
    }

    // Nodes
    nodes.forEach(n => {
      ctx.fillStyle = dark ? 'rgba(255,255,255,0.15)' : 'rgba(0,0,0,0.1)';
      ctx.beginPath();
      ctx.arc(n.x, n.y, 2, 0, Math.PI * 2);
      ctx.fill();
    });

    // Packets
    for (let i = packets.length - 1; i >= 0; i--) {
      const p = packets[i];
      p.t += PACKET_SPEED;
      if (p.t >= 1) { packets.splice(i, 1); continue; }
      const na = nodes[p.a], nb = nodes[p.b];
      const x = na.x + (nb.x - na.x) * p.t;
      const y = na.y + (nb.y - na.y) * p.t;
      const fade = Math.sin(p.t * Math.PI);
      ctx.fillStyle = dark
        ? `rgba(212,144,78,${fade * 0.55})`
        : `rgba(192,122,58,${fade * 0.45})`;
      ctx.beginPath();
      ctx.arc(x, y, 2.5, 0, Math.PI * 2);
      ctx.fill();
    }

    spawnPackets();
    requestAnimationFrame(draw);
  }

  resize();
  window.addEventListener('resize', resize);
  draw();
</script>
