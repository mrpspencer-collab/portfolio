    font-size: 14px;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 4px;
  }
  .body :global(.cs-carousel-caption p) {
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0;
    max-width: 100%;
  }
  .body :global(.cs-carousel-nav) {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
  }
  .body :global(.cs-carousel-btn) {
    background: var(--bg-surface);
    border: 1px solid var(--border-strong);
    color: var(--fg);
    width: 36px;
    height: 36px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .body :global(.cs-carousel-btn:hover) { background: var(--bg-muted); }
  .body :global(.cs-carousel-btn:disabled) { opacity: 0.35; cursor: default; }
  .body :global(.cs-carousel-counter) {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-subtle);
  }

  /* Auto-scroll toggle */
  .body :global(.cs-pan-toggle) {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-left: auto;
    cursor: pointer;
    user-select: none;
  }
  .body :global(.cs-pan-toggle-input) { display: none; }
  .body :global(.cs-pan-toggle-track) {
    width: 30px;
    height: 17px;
    background: var(--border-strong);
    border-radius: 9px;
    position: relative;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .body :global(.cs-pan-toggle-track::after) {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--bg-surface);
    transition: transform 0.2s;
  }
  .body :global(.cs-pan-toggle-input:checked ~ .cs-pan-toggle-track) {
    background: var(--accent);
  }
  .body :global(.cs-pan-toggle-input:checked ~ .cs-pan-toggle-track::after) {
    transform: translateX(13px);
  }
  .body :global(.cs-pan-toggle-text) {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-subtle);
  }

  @media (max-width: 640px) {
    .breadcrumb { padding: 12px 20px; }
    .content-wrap { padding: 0 20px; }
    .thumb { height: 50vw; min-height: 260px; margin: 24px 0; }
    h1 { font-size: 28px; }
    .body :global(p), .body :global(ul), .body :global(ol) { max-width: 100%; }
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.88);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    cursor: zoom-out;
  }
  .lightbox.open {
    opacity: 1;
    pointer-events: all;
  }
  .lightbox.zoomed {
    align-items: flex-start;
    justify-content: center;
    overflow-y: auto;
    padding: 60px 24px 40px;
    cursor: default;
  }
  .lightbox img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
    cursor: zoom-in;
    transition: max-width 0.2s ease, max-height 0.2s ease;
  }
  .lightbox.zoomed img {
    max-width: min(90vw, 1600px);
    max-height: none;
    cursor: zoom-out;
  }
  .lightbox-close {
    position: fixed;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 28px;
    cursor: pointer;
    line-height: 1;
    padding: 4px 8px;
    transition: color 0.15s;
    z-index: 10000;
  }
  .lightbox-close:hover { color: #fff; }
  .body :global(img) { cursor: zoom-in; }
  .body :global(.cs-carousel--pan img) { cursor: default; }
</style>

