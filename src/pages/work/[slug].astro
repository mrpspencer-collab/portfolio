---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const isPublic = import.meta.env.PUBLIC_BUILD === 'true';
  const projects = await getCollection('projects');
  return projects
    .filter(p => !isPublic || p.slug !== 'atlas')
    .map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { data: d } = project;
const { Content } = await project.render();

const allProjects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const currentIndex = allProjects.findIndex(p => p.slug === project.slug);
const prevProject = currentIndex > 0 ? allProjects[currentIndex - 1] : null;
const nextProject = currentIndex < allProjects.length - 1 ? allProjects[currentIndex + 1] : null;
---
<Base title={d.title} noindex={project.slug === 'atlas'}>
  <Nav />
  <main>
    <div class="breadcrumb">
      <a href="/">Work</a>
      <span class="arrow">→</span>
      <span class="current">{d.title}</span>
    </div>

    {project.slug === 'atlas' && <span id="atlas-encrypt-start" aria-hidden="true" style="display:none"></span>}
    <div class="content-wrap">
      {d.heroThumb !== false && (
        <div class="thumb" style={`background:${d.thumbBg}`}>
          {d.thumb
            ? <img src={d.thumb} alt={d.title} />
            : <span style={`font-family:var(--font-mono);font-size:14px;color:${d.thumbTextColor}`}>{d.title} — {d.subtitle}</span>}
        </div>
      )}

      <div class="content">
        <div class="tags">
          {d.tags.map(t => <span class="tag">{t}</span>)}
          {d.status && <span class="tag tag-accent">{d.status}</span>}
        </div>
        <p class="overline">{d.title}</p>
        <h1>{d.subtitle}</h1>
        {d.role && <p class="role">{d.role}</p>}

        <div class="body">
          <Content />
        </div>

        {d.metrics.length > 0 && (
          <div class="outcomes">
            <p class="overline" style="margin-bottom:16px">Outcomes</p>
            <div class="metrics">
              {d.metrics.map(m => (
                <div class="metric">
                  <span class="metric-val">
                    {m.startsWith('+') ? m.split(' ')[0] : '→'}
                  </span>
                  <span class="metric-label">
                    {m.startsWith('+') ? m.slice(m.indexOf(' ') + 1) : m}
                  </span>
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="case-nav">
          <div class="case-nav-item">
            {prevProject && (
              <a href={`/work/${prevProject.slug}`} class="case-nav-link case-nav-prev">
                <span class="case-nav-label">← Previous</span>
                <span class="case-nav-title">{prevProject.data.title}</span>
              </a>
            )}
          </div>
          <a href="/" class="case-nav-home">All work</a>
          <div class="case-nav-item case-nav-item--right">
            {nextProject && (
              <a href={`/work/${nextProject.slug}`} class="case-nav-link case-nav-next">
                <span class="case-nav-label">Next →</span>
                <span class="case-nav-title">{nextProject.data.title}</span>
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
    {project.slug === 'atlas' && <span id="atlas-encrypt-end" aria-hidden="true" style="display:none"></span>}
  </main>
  <Footer />
</Base>

<style>
  main { padding-top: 64px; }

  .breadcrumb {
    border-bottom: 1px solid var(--border);
    padding: 12px 40px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 12px;
  }
  .breadcrumb a { color: var(--fg-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--fg); }
  .arrow { color: var(--fg-subtle); }
  .current { color: var(--fg); font-weight: 500; }

  .content-wrap {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .thumb {
    height: 70vh;
    min-height: 480px;
    max-height: 780px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin: 40px 0;
    border-radius: var(--radius);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: 32px;
  }
  :global([data-theme="dark"]) .thumb {
    background: var(--bg-subtle) !important;
  }

  .content { max-width: 100%; padding-bottom: 96px; }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .content .overline { margin-bottom: 10px; }

  .role {
    font-size: 13px;
    font-weight: 500;
    color: var(--fg-subtle);
    margin-bottom: 32px;
    font-family: var(--font-body);
  }

  h1 {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--fg);
    margin-bottom: 24px;
    max-width: 760px;
  }

  .body {
    font-size: 17px;
    line-height: 1.7;
    color: var(--fg-muted);
    margin-bottom: 32px;
  }
  .body :global(p) { margin-bottom: 16px; max-width: 600px; }
  .body :global(p:last-child) { margin-bottom: 0; }

  .body :global(h2) {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 56px 0 16px;
    max-width: 100%;
  }
  .body :global(h3) {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--fg);
    margin: 32px 0 10px;
    max-width: 100%;
  }
  .body :global(h4) {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin: 28px 0 8px;
  }
  .body :global(ul), .body :global(ol) {
    padding-left: 20px;
    margin-bottom: 16px;
    max-width: 600px;
  }
  .body :global(li) {
    margin-bottom: 6px;
    line-height: 1.6;
  }
  .body :global(li:last-child) { margin-bottom: 0; }
  .body :global(strong) {
    font-weight: 600;
    color: var(--fg);
  }
  .body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }
  .body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 4px 0 4px 20px;
    margin: 32px 0;
    color: var(--fg-muted);
    font-style: italic;
    max-width: 600px;
  }
  .body :global(blockquote p) {
    margin: 0 !important;
    font-size: 17px;
    line-height: 1.65;
  }
  .body :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    display: block;
    margin: 32px 0;
    border: 1px solid var(--border);
  }

  .body :global(.cs-split) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
    margin: 32px 0;
  }
  .body :global(.cs-split-body) {
    font-size: 17px;
    line-height: 1.7;
    color: var(--fg-muted);
  }
  .body :global(.cs-split-body p) { margin-bottom: 16px; }
  .body :global(.cs-split-body ul) { padding-left: 20px; }
  .body :global(.cs-split-body li) { margin-bottom: 6px; }
  .body :global(.cs-split-image img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius) var(--radius) 0 0;
    border: 1px solid var(--border);
    border-bottom: none;
    margin: 0;
    display: block;
  }
  .body :global(.cs-split-image figure) {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .body :global(.cs-split-image figure img) {
    border-radius: 0;
    border: none;
    border-bottom: 1px solid var(--border);
  }
  .body :global(figcaption) {
    font-size: 12px;
    color: var(--fg-subtle);
    padding: 8px 12px;
    background: var(--bg-muted);
    line-height: 1.4;
  }
  .body :global(.cs-image-pair) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .body :global(.cs-image-pair figure) {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .body :global(.cs-image-pair img) {
    width: 100%;
    height: auto;
    border-radius: 0;
    border: none;
    border-bottom: 1px solid var(--border);
    margin: 0;
    display: block;
  }

  @media (max-width: 640px) {
    .body :global(.cs-split) { grid-template-columns: 1fr; }
    .body :global(.cs-image-pair) { grid-template-columns: 1fr 1fr; }
  }

  .outcomes {
    max-width: 100%;
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 28px;
    margin-bottom: 36px;
  }
  .metrics { display: flex; flex-direction: column; gap: 10px; }
  .metric { display: flex; align-items: center; gap: 12px; }
  .metric-val {
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 500;
    color: var(--accent);
  }
  .metric-label { font-size: 14px; color: var(--fg-muted); }

  .case-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 16px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
    margin-top: 16px;
  }
  .case-nav-item { display: flex; }
  .case-nav-item--right { justify-content: flex-end; }
  .case-nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .case-nav-link:hover { opacity: 0.65; }
  .case-nav-prev { align-items: flex-start; }
  .case-nav-next { align-items: flex-end; }
  .case-nav-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    font-family: var(--font-body);
  }
  .case-nav-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--fg);
  }
  .case-nav-home {
    font-size: 12px;
    color: var(--fg-subtle);
    text-decoration: none;
    font-family: var(--font-body);
    white-space: nowrap;
  }
  .case-nav-home:hover { color: var(--fg); }
  @media (max-width: 640px) {
    .case-nav {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }
    .case-nav-home {
      grid-column: 1 / -1;
      text-align: center;
      order: -1;
    }
    .case-nav-item--right { justify-content: flex-end; }
  }

  /* Two-column text layout */
  .body :global(.cs-columns) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin: 24px 0 32px;
  }
  .body :global(.cs-col-label) {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin-bottom: 12px !important;
    max-width: 100% !important;
  }
  .body :global(.cs-columns ul) {
    padding-left: 16px;
    margin: 0;
    max-width: 100%;
  }
  .body :global(.cs-columns li) { margin-bottom: 8px; font-size: 15px; }

  /* Data table */
  .body :global(.cs-table-wrap) {
    margin: 24px 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .body :global(.cs-table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .body :global(.cs-table thead) {
    background: var(--bg-muted);
  }
  .body :global(.cs-table th) {
    text-align: left;
    padding: 10px 16px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    border-bottom: 1px solid var(--border);
  }
  .body :global(.cs-table td) {
    padding: 12px 16px;
    color: var(--fg-muted);
    border-bottom: 1px solid var(--border);
    line-height: 1.5;
    vertical-align: top;
  }
  .body :global(.cs-table td:first-child) {
    font-weight: 600;
    color: var(--fg);
    white-space: nowrap;
  }
  .body :global(.cs-table tbody tr:last-child td) {
    border-bottom: none;
  }
  .body :global(.cs-table-row--accent td) {
    background: color-mix(in srgb, var(--accent) 8%, var(--bg-surface));
  }
  .body :global(.cs-table-row--accent td:first-child) {
    color: var(--accent);
  }

  /* Persona cards */
  .body :global(.cs-persona-grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin: 24px 0 32px;
  }
  .body :global(.cs-persona-card) {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    background: var(--bg-surface);
  }
  .body :global(.cs-persona-card--accent) {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, var(--bg-surface));
  }
  .body :global(.cs-persona-label) {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin: 0 0 12px !important;
    max-width: 100% !important;
  }
  .body :global(.cs-persona-card--accent .cs-persona-label) {
    color: var(--accent);
  }
  .body :global(.cs-persona-name) {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--fg);
    margin: 0 0 12px !important;
    max-width: 100% !important;
  }
  .body :global(.cs-persona-body) {
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-muted);
    margin: 0 !important;
    max-width: 100% !important;
  }
  @media (max-width: 640px) {
    .body :global(.cs-persona-grid) { grid-template-columns: 1fr; }
  }

  /* Featured final design */
  .body :global(.cs-featured) {
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin: 24px 0;
  }
  .body :global(.cs-featured img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    border: none;
    border-bottom: 1px solid var(--border);
    margin: 0;
  }
  .body :global(.cs-featured-body) {
    padding: 20px 24px;
  }
  .body :global(.cs-featured-body ul) {
    padding-left: 16px;
    margin: 0;
    max-width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px 24px;
  }
  .body :global(.cs-featured-body li) { font-size: 14px; margin-bottom: 4px; }

  @media (max-width: 640px) {
    .body :global(.cs-columns) { grid-template-columns: 1fr; }
    .body :global(.cs-featured-body ul) { grid-template-columns: 1fr; }
  }

  /* Carousel */
  .body :global(.cs-carousel) {
    margin: 32px 0;
  }
  .body :global(.cs-split-image .cs-carousel) {
    margin-top: 0;
  }
  .body :global(.cs-split-image .cs-carousel-slide img) {
    height: 320px;
  }
  .body :global(.cs-carousel-track-wrap) {
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-muted);
  }
  .body :global(.cs-carousel-track) {
    display: flex;
    transition: transform 0.35s ease;
    align-items: stretch;
  }
  .body :global(.cs-carousel-slide) {
    min-width: 100%;
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
  }
  .body :global(.cs-carousel-slide img) {
    width: 100%;
    height: 480px;
    object-fit: cover;
    object-position: top;
    display: block;
    border-radius: 0;
    border: none;
    margin: 0 !important;
  }

  /* Contain carousel — shows full image without cropping */
  .body :global(.cs-carousel--contain .cs-carousel-track-wrap) {
    background: none;
    border: none;
  }
  .body :global(.cs-carousel--contain .cs-carousel-slide) {
    background: none;
  }
  .body :global(.cs-carousel--contain .cs-carousel-slide img) {
    width: 100%;
    height: 480px;
    object-fit: cover;
    background: none;
    border: none;
  }

  /* Panning carousel — JS controls object-position; mouse overrides auto-pan */
  .body :global(.cs-carousel--pan .cs-carousel-slide img) {
    object-position: center 0%;
  }
  .body :global(.cs-carousel--pan .cs-carousel-track-wrap) {
    cursor: default;
  }

  @media (max-width: 640px) {
    .body :global(.cs-carousel-slide img) {
      height: auto;
      max-height: 280px;
      object-fit: contain;
      background: var(--bg-muted);
    }
  }
  .body :global(.cs-carousel-caption) {
    padding: 16px 20px;
    background: var(--bg-muted);
    border-top: 1px solid var(--border);
    flex: 1;
  }
  .body :global(.cs-carousel-caption strong) {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 4px;
  }
  .body :global(.cs-carousel-caption p) {
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0;
    max-width: 100%;
  }
  .body :global(.cs-carousel-nav) {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
  }
  .body :global(.cs-carousel-btn) {
    background: var(--bg-surface);
    border: 1px solid var(--border-strong);
    color: var(--fg);
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .body :global(.cs-carousel-btn:hover) { background: var(--bg-muted); }
  .body :global(.cs-carousel-btn:disabled) { opacity: 0.35; cursor: default; }
  .body :global(.cs-carousel-counter) {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-subtle);
  }

  /* Auto-scroll toggle */
  .body :global(.cs-pan-toggle) {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-left: auto;
    cursor: pointer;
    user-select: none;
  }
  .body :global(.cs-pan-toggle-input) { display: none; }
  .body :global(.cs-pan-toggle-track) {
    width: 30px;
    height: 17px;
    background: var(--border-strong);
    border-radius: 9px;
    position: relative;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .body :global(.cs-pan-toggle-track::after) {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--bg-surface);
    transition: transform 0.2s;
  }
  .body :global(.cs-pan-toggle-input:checked ~ .cs-pan-toggle-track) {
    background: var(--accent);
  }
  .body :global(.cs-pan-toggle-input:checked ~ .cs-pan-toggle-track::after) {
    transform: translateX(13px);
  }
  .body :global(.cs-pan-toggle-text) {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-subtle);
  }

  /* Vibe Coded — chrome-store-style cards */
  .body :global(.cs-ext-list) {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin: 32px 0;
  }
  .body :global(.cs-ext-card) {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 1px 6px rgba(0,0,0,0.06);
  }
  .body :global(.cs-ext-header) {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 24px 14px;
  }
  .body :global(.cs-ext-header-info) {
    flex: 1;
    min-width: 0;
  }
  .body :global(.cs-ext-header .btn) {
    margin-left: auto;
    flex-shrink: 0;
    text-decoration: none !important;
    white-space: nowrap;
  }
  .body :global(.cs-ext-icon) {
    width: 44px;
    height: 44px;
    border-radius: 6px;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }
  .body :global(.cs-ext-title) {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--fg);
    margin: 0;
    letter-spacing: -0.02em;
    max-width: 100% !important;
  }
  .body :global(.cs-ext-tags) {
    display: flex;
    gap: 8px;
    padding: 0 24px 16px;
    flex-wrap: wrap;
  }
  .body :global(.cs-ext-body) {
    display: grid;
    grid-template-columns: 1fr 2fr;
    border-top: 1px solid var(--border);
    min-height: 360px;
  }
  .body :global(.cs-ext-text) {
    padding: 20px 24px;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }
  .body :global(.cs-ext-text p) {
    font-size: 14px;
    line-height: 1.65;
    color: var(--fg-muted);
    margin-bottom: 14px !important;
    max-width: 100% !important;
  }
  .body :global(.cs-ext-takeaway) {
    font-size: 13px;
    font-style: italic;
    color: var(--fg) !important;
    margin-top: auto !important;
    margin-bottom: 0 !important;
    padding-left: 12px;
    border-left: 2px solid var(--accent);
    line-height: 1.5;
    max-width: 100% !important;
  }
  .body :global(.cs-ext-images) {
    display: flex;
    background: var(--bg-surface);
    overflow: hidden;
  }
  .body :global(.cs-ext-main) {
    flex: 1;
    overflow: hidden;
    background: var(--bg-surface);
  }
  .body :global(.cs-ext-main-img) {
    width: 100%;
    height: 100%;
    min-height: 200px;
    object-fit: contain;
    object-position: center;
    padding: 16px;
    display: block;
    border-radius: 0 !important;
    border: none !important;
    margin: 0 !important;
    box-sizing: border-box;
    cursor: zoom-in;
  }
  .body :global(.cs-ext-thumbs) {
    width: 96px;
    flex-shrink: 0;
    border-left: 1px solid var(--border);
    background: var(--bg-surface) !important;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 8px;
    overflow-y: auto;
  }
  .body :global(.cs-ext-thumb) {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top;
    border-radius: var(--radius-sm);
    cursor: pointer;
    border: 2px solid transparent !important;
    opacity: 0.55;
    transition: opacity 0.15s, border-color 0.15s;
    display: block;
    margin: 0 !important;
  }
  .body :global(.cs-ext-thumb:hover) { opacity: 0.85; }
  .body :global(.cs-ext-thumb--active) {
    border-color: var(--accent) !important;
    opacity: 1;
  }

  @media (max-width: 640px) {
    .breadcrumb { padding: 12px 20px; }
    .content-wrap { padding: 0 20px; }
    .thumb { height: 50vw; min-height: 260px; margin: 24px 0; }
    h1 { font-size: 28px; }
    .body :global(p), .body :global(ul), .body :global(ol) { max-width: 100%; }
    .body :global(.cs-ext-body) { grid-template-columns: 1fr; min-height: unset; }
    .body :global(.cs-ext-text) { border-right: none; border-bottom: 1px solid var(--border); }
    .body :global(.cs-ext-thumbs) { display: none; }
    .body :global(.cs-ext-header) { flex-wrap: nowrap; padding-bottom: 12px; }
    .body :global(.cs-ext-title) { font-size: 17px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .body :global(.cs-ext-header .btn) {
      background: transparent;
      border: none;
      box-shadow: none;
      color: var(--accent);
      padding: 0;
      font-size: 12px;
      font-weight: 500;
      white-space: nowrap;
      margin-left: auto;
    }
    .body :global(.cs-ext-title) { font-size: 17px; }
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.88);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    cursor: zoom-out;
  }
  .lightbox.open {
    opacity: 1;
    pointer-events: all;
  }
  .lightbox.zoomed {
    align-items: flex-start;
    justify-content: center;
    overflow-y: auto;
    padding: 60px 24px 40px;
    cursor: default;
  }
  .lightbox img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-sm);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
    cursor: zoom-in;
    transition: max-width 0.2s ease, max-height 0.2s ease;
  }
  .lightbox.zoomed img {
    max-width: min(90vw, 1600px);
    max-height: none;
    cursor: zoom-out;
  }
  .lightbox-close {
    position: fixed;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 28px;
    cursor: pointer;
    line-height: 1;
    padding: 4px 8px;
    transition: color 0.15s;
    z-index: 10000;
  }
  .lightbox-close:hover { color: #fff; }
  .lightbox-prev,
  .lightbox-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.12);
    border: none;
    color: #fff;
    font-size: 22px;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    transition: background 0.15s;
  }
  .lightbox-prev { left: 20px; }
  .lightbox-next { right: 20px; }
  .lightbox-prev:hover,
  .lightbox-next:hover { background: rgba(255, 255, 255, 0.22); }
  .lightbox-prev:disabled,
  .lightbox-next:disabled { opacity: 0.3; cursor: default; }
  .lightbox.has-nav .lightbox-prev,
  .lightbox.has-nav .lightbox-next { display: flex; }
  .body :global(img) { cursor: zoom-in; }
  .body :global(.cs-carousel--pan img) { cursor: default; }
</style>

