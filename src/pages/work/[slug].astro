    height: 320px;
  }
  .body :global(.cs-carousel-track-wrap) {
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-muted);
  }
  .body :global(.cs-carousel-track) {
    display: flex;
    transition: transform 0.35s ease;
    align-items: stretch;
  }
  .body :global(.cs-carousel-slide) {
    min-width: 100%;
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
  }
  .body :global(.cs-carousel-slide img) {
    width: 100%;
    height: 480px;
    object-fit: cover;
    object-position: top;
    display: block;
    border-radius: 0;
    border: none;
    margin: 0 !important;
  }

  /* Contain carousel — shows full image without cropping */
  .body :global(.cs-carousel--contain .cs-carousel-track-wrap) {
    background: none;
    border: none;
  }
  .body :global(.cs-carousel--contain .cs-carousel-slide) {
    background: none;
  }
  .body :global(.cs-carousel--contain .cs-carousel-slide img) {
    width: 100%;
    height: 480px;
    object-fit: cover;
    background: none;
    border: none;
  }

  /* Panning carousel — JS controls object-position; mouse overrides auto-pan */
  .body :global(.cs-carousel--pan .cs-carousel-slide img) {
    object-position: center 0%;
  }
  .body :global(.cs-carousel--pan .cs-carousel-track-wrap) {
    cursor: default;
  }

  @media (max-width: 640px) {
    .body :global(.cs-carousel-slide img) {
      height: auto;
      max-height: 280px;
      object-fit: contain;
      background: var(--bg-muted);
    }
  }
  .body :global(.cs-carousel-caption) {
