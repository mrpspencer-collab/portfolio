    font-size: 14px;
    font-family: inherit;
    background: var(--bg-surface, #fff);
    color: var(--fg, #111);
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.15s;
  }
  #pg-overlay input:focus,
  #pg-overlay textarea:focus { border-color: var(--accent, #C07A3A); }
  #pg-overlay textarea { resize: vertical; }
  #pg-overlay button[type=submit],
  #pg-submit {
    padding: 10px 20px;
    background: var(--fg, #111);
    color: var(--bg, #fff);
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.15s;
    align-self: flex-start;
  }
  #pg-overlay button[type=submit]:hover,
  #pg-submit:hover { opacity: 0.75; }
  #pg-error { font-size: 13px; color: #c0392b; margin: 0; }
  #pg-request-toggle {
    background: none;
    border: none;
    padding: 0;
    font-size: 13px;
    color: var(--accent, #C07A3A);
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    margin-top: 4px;
  }
  #pg-request-toggle:hover { text-decoration: underline; }
  #pg-request-form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 1px solid var(--border, #ddd);
    padding-top: 16px;
    margin-top: 4px;
  }
  #pg-request-form form { display: flex; flex-direction: column; gap: 8px; }
  #pg-sent { font-size: 14px; color: var(--fg-muted, #666); margin: 0; }
</style>

<script>
  // Lightbox
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.add('open');
    lightbox.classList.remove('zoomed');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('open', 'zoomed');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLImageElement>('.body img').forEach(img => {
    if (img.closest('.cs-carousel--pan')) return;
    img.addEventListener('click', () => openLightbox(img.src, img.alt));
  });

  lightbox.addEventListener('click', closeLightbox);
  lightboxImg.addEventListener('click', e => {
    e.stopPropagation();
    lightbox.classList.toggle('zoomed');
    lightbox.scrollTop = 0;
  });
  document.getElementById('lightbox-close')!.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

  document.querySelectorAll<HTMLElement>('.cs-carousel').forEach(carousel => {
    const track = carousel.querySelector<HTMLElement>('.cs-carousel-track')!;
    const slides = carousel.querySelectorAll('.cs-carousel-slide');
    const prev = carousel.querySelector<HTMLButtonElement>('.cs-carousel-prev')!;
    const next = carousel.querySelector<HTMLButtonElement>('.cs-carousel-next')!;
    const counter = carousel.querySelector<HTMLElement>('.cs-carousel-counter')!;
    let current = 0;

    function go(n: number) {
      current = Math.max(0, Math.min(n, slides.length - 1));
      track.style.transform = `translateX(-${current * 100}%)`;
      counter.textContent = `${current + 1} / ${slides.length}`;
      prev.disabled = current === 0;
      next.disabled = current === slides.length - 1;
    }

    prev.addEventListener('click', () => go(current - 1));
    next.addEventListener('click', () => go(current + 1));
    go(0);
  });

  // Panning carousels — off by default; toggle enables auto-pan; mouse always controls on hover
  document.querySelectorAll<HTMLElement>('.cs-carousel--pan').forEach(carousel => {
    const wrap = carousel.querySelector<HTMLElement>('.cs-carousel-track-wrap')!;
    const imgs = carousel.querySelectorAll<HTMLImageElement>('.cs-carousel-slide img');
    const nav = carousel.querySelector<HTMLElement>('.cs-carousel-nav')!;
    let pos = 0;
    let dir = 1;
    let hovered = false;
    let autoPan = false;

    // Inject toggle switch into nav
    const label = document.createElement('label');
    label.className = 'cs-pan-toggle';
    label.innerHTML = `<input type="checkbox" class="cs-pan-toggle-input" /><span class="cs-pan-toggle-track"></span><span class="cs-pan-toggle-text">Auto-scroll</span>`;
    nav.appendChild(label);
    const input = label.querySelector<HTMLInputElement>('.cs-pan-toggle-input')!;
    input.addEventListener('change', () => { autoPan = input.checked; });

    function setPos(p: number) {
      pos = Math.max(0, Math.min(100, p));
      imgs.forEach(img => { img.style.objectPosition = `center ${pos}%`; });
    }

    (function tick() {
      if (autoPan && !hovered) {
        if (pos >= 100) dir = -1;
        if (pos <= 0) dir = 1;
        setPos(pos + dir * 0.04);
      }
      requestAnimationFrame(tick);
    })();

    wrap.addEventListener('mouseenter', () => { hovered = true; });
    wrap.addEventListener('mouseleave', () => { hovered = false; });

    wrap.addEventListener('wheel', (e: WheelEvent) => {
      e.preventDefault();
      setPos(pos + e.deltaY * 0.05);
    }, { passive: false });
  });

  // Atlas password gate
  const overlay = document.getElementById('pg-overlay');
  if (overlay) {
    const HASH = '8f40d29c6591983ace8fd1bf3b517cbe7290e2fc26d2cab47739510b40b75ea7';
    const KEY  = 'pa-atlas-auth';

    async function sha256(str: string) {
      const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
      return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
    }

    if (localStorage.getItem(KEY) === '1') {
      overlay.remove();
    } else {
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';

      const input  = document.getElementById('pg-input') as HTMLInputElement;
      const submit = document.getElementById('pg-submit')!;
      const error  = document.getElementById('pg-error')!;

      async function attempt() {
        const h = await sha256(input.value.trim());
        if (h === HASH) {
          localStorage.setItem(KEY, '1');
          overlay!.remove();
          document.body.style.overflow = '';
        } else {
          error.style.display = 'block';
          input.value = '';
          input.focus();
        }
      }

      submit.addEventListener('click', attempt);
      input.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter') attempt(); });

      const toggle      = document.getElementById('pg-request-toggle')!;
      const requestForm = document.getElementById('pg-request-form')!;
      toggle.addEventListener('click', () => {
        const open = requestForm.style.display !== 'none';
        requestForm.style.display = open ? 'none' : 'flex';
        toggle.textContent = open ? 'Request access →' : 'Hide request form';
      });

      const form = document.getElementById('pg-form') as HTMLFormElement;
      const sent = document.getElementById('pg-sent')!;
      form.addEventListener('submit', async (e: Event) => {
        e.preventDefault();
        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          if (res.ok) {
            form.style.display = 'none';
            sent.style.display = 'block';
          }
        } catch (_) {}
      });
    }
  }
</script>
