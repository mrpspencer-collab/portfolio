---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { data: d } = project;
const { Content } = await project.render();
---
<Base title={d.title}>
  <Nav />
  <main>
    <div class="breadcrumb">
      <a href="/">Work</a>
      <span class="arrow">→</span>
      <span class="current">{d.title}</span>
    </div>

    <div class="content-wrap">
      <div class="thumb" style={`background:${d.thumbBg}`}>
        {d.thumb
          ? <img src={d.thumb} alt={d.title} />
          : <span style={`font-family:var(--font-mono);font-size:14px;color:${d.thumbTextColor}`}>{d.title} — {d.subtitle}</span>}
      </div>

      <div class="content">
        <div class="tags">
          {d.tags.map(t => <span class="tag">{t}</span>)}
          {d.status && <span class="tag tag-accent">{d.status}</span>}
        </div>
        <p class="overline">{d.title}</p>
        <h1>{d.subtitle}</h1>
        {d.role && <p class="role">{d.role}</p>}

        <div class="body">
          <Content />
        </div>

        {d.metrics.length > 0 && (
          <div class="outcomes">
            <p class="overline" style="margin-bottom:16px">Outcomes</p>
            <div class="metrics">
              {d.metrics.map(m => (
                <div class="metric">
                  <span class="metric-val">
                    {m.startsWith('+') ? m.split(' ')[0] : '→'}
                  </span>
                  <span class="metric-label">
                    {m.startsWith('+') ? m.slice(m.indexOf(' ') + 1) : m}
                  </span>
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="actions">
          <a href="#" class="btn btn-primary btn-md">{d.cta} →</a>
          <a href="/" class="btn btn-ghost btn-md">← Back to Work</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>

<style>
  main { padding-top: 64px; }

  .breadcrumb {
    border-bottom: 1px solid var(--border);
    padding: 12px 40px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 12px;
  }
  .breadcrumb a { color: var(--fg-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--fg); }
  .arrow { color: var(--fg-subtle); }
  .current { color: var(--fg); font-weight: 500; }

  .content-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .thumb {
    height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin: 40px 0;
    border-radius: 8px;
  }
  .thumb img {
    width: 85%;
    height: 85%;
    object-fit: contain;
    display: block;
  }

  .content { max-width: 100%; padding-bottom: 96px; }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 16px;
    max-width: 640px;
  }
  .content .overline { margin-bottom: 10px; max-width: 640px; }

  .role {
    font-size: 13px;
    font-weight: 500;
    color: var(--fg-subtle);
    margin-bottom: 32px;
    font-family: var(--font-body);
    max-width: 640px;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--fg);
    margin-bottom: 24px;
    max-width: 640px;
  }

  .body {
    font-size: 17px;
    line-height: 1.7;
    color: var(--fg-muted);
    margin-bottom: 32px;
  }
  .body :global(p) { margin-bottom: 16px; max-width: 640px; }
  .body :global(p:last-child) { margin-bottom: 0; }

  .body :global(h2) {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 48px 0 16px;
    max-width: 640px;
  }
  .body :global(h3) {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--fg);
    margin: 32px 0 10px;
    max-width: 640px;
  }
  .body :global(h4) {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin: 28px 0 8px;
  }
  .body :global(ul), .body :global(ol) {
    padding-left: 20px;
    margin-bottom: 16px;
    max-width: 640px;
  }
  .body :global(li) {
    margin-bottom: 6px;
    line-height: 1.6;
  }
  .body :global(li:last-child) { margin-bottom: 0; }
  .body :global(strong) {
    font-weight: 600;
    color: var(--fg);
  }
  .body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }
  .body :global(img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 32px 0;
    border: 1px solid var(--border);
  }

  .body :global(.cs-split) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
    margin: 32px 0;
  }
  .body :global(.cs-split-body) {
    font-size: 17px;
    line-height: 1.7;
    color: var(--fg-muted);
  }
  .body :global(.cs-split-body p) { margin-bottom: 16px; }
  .body :global(.cs-split-body ul) { padding-left: 20px; }
  .body :global(.cs-split-body li) { margin-bottom: 6px; }
  .body :global(.cs-split-image img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--border);
    margin: 0;
  }
  .body :global(.cs-image-pair) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .body :global(.cs-image-pair img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--border);
    margin: 0;
  }

  @media (max-width: 640px) {
    .body :global(.cs-split) { grid-template-columns: 1fr; }
    .body :global(.cs-image-pair) { grid-template-columns: 1fr 1fr; }
  }

  .outcomes {
    max-width: 640px;
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 24px 28px;
    margin-bottom: 36px;
  }
  .metrics { display: flex; flex-direction: column; gap: 10px; }
  .metric { display: flex; align-items: center; gap: 12px; }
  .metric-val {
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 500;
    color: var(--accent);
  }
  .metric-label { font-size: 14px; color: var(--fg-muted); }

  .actions { display: flex; gap: 12px; flex-wrap: wrap; max-width: 640px; }

  /* Carousel */
  .body :global(.cs-carousel) {
    margin: 32px 0;
  }
  .body :global(.cs-carousel-track-wrap) {
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--border);
  }
  .body :global(.cs-carousel-track) {
    display: flex;
    transition: transform 0.35s ease;
  }
  .body :global(.cs-carousel-slide) {
    min-width: 100%;
  }
  .body :global(.cs-carousel-slide img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    border: none;
    margin: 0;
  }
  .body :global(.cs-carousel-caption) {
    padding: 16px 20px;
    background: var(--bg-muted);
    border-top: 1px solid var(--border);
  }
  .body :global(.cs-carousel-caption strong) {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 4px;
  }
  .body :global(.cs-carousel-caption p) {
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0;
    max-width: 100%;
  }
  .body :global(.cs-carousel-nav) {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
  }
  .body :global(.cs-carousel-btn) {
    background: var(--bg-surface);
    border: 1px solid var(--border-strong);
    color: var(--fg);
    width: 36px;
    height: 36px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .body :global(.cs-carousel-btn:hover) { background: var(--bg-muted); }
  .body :global(.cs-carousel-btn:disabled) { opacity: 0.35; cursor: default; }
  .body :global(.cs-carousel-counter) {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-subtle);
  }

  @media (max-width: 640px) {
    .breadcrumb { padding: 12px 20px; }
    .content-wrap { padding: 0 20px; }
    .thumb { height: 220px; margin: 24px 0; }
    h1 { font-size: 32px; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.cs-carousel').forEach(carousel => {
    const track = carousel.querySelector<HTMLElement>('.cs-carousel-track')!;
    const slides = carousel.querySelectorAll('.cs-carousel-slide');
    const prev = carousel.querySelector<HTMLButtonElement>('.cs-carousel-prev')!;
    const next = carousel.querySelector<HTMLButtonElement>('.cs-carousel-next')!;
    const counter = carousel.querySelector<HTMLElement>('.cs-carousel-counter')!;
    let current = 0;

    function go(n: number) {
      current = Math.max(0, Math.min(n, slides.length - 1));
      track.style.transform = `translateX(-${current * 100}%)`;
      counter.textContent = `${current + 1} / ${slides.length}`;
      prev.disabled = current === 0;
      next.disabled = current === slides.length - 1;
    }

    prev.addEventListener('click', () => go(current - 1));
    next.addEventListener('click', () => go(current + 1));
    go(0);
  });
</script>
