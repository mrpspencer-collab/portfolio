---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { data: d } = project;
const { Content } = await project.render();
---
<Base title={d.title}>
  <Nav />
  <main>
    <div class="breadcrumb">
      <a href="/">Work</a>
      <span class="arrow">→</span>
      <span class="current">{d.title}</span>
    </div>

    <div class="content-wrap">
      <div class="thumb" style={`background:${d.thumbBg}`}>
        {d.thumb
          ? <img src={d.thumb} alt={d.title} />
          : <span style={`font-family:var(--font-mono);font-size:14px;color:${d.thumbTextColor}`}>{d.title} — {d.subtitle}</span>}
      </div>

      <div class="content">
        <div class="tags">
          {d.tags.map(t => <span class="tag">{t}</span>)}
          {d.status && <span class="tag tag-accent">{d.status}</span>}
        </div>
        <p class="overline">{d.title}</p>
        <h1>{d.subtitle}</h1>
        {d.role && <p class="role">{d.role}</p>}

        <div class="body">
          <Content />
        </div>

        {d.metrics.length > 0 && (
          <div class="outcomes">
            <p class="overline" style="margin-bottom:16px">Outcomes</p>
            <div class="metrics">
              {d.metrics.map(m => (
                <div class="metric">
                  <span class="metric-val">
                    {m.startsWith('+') ? m.split(' ')[0] : '→'}
                  </span>
                  <span class="metric-label">
                    {m.startsWith('+') ? m.slice(m.indexOf(' ') + 1) : m}
                  </span>
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="actions">
          <a href="#" class="btn btn-primary btn-md">{d.cta} →</a>
          <a href="/" class="btn btn-ghost btn-md">← Back to Work</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>

<style>
  main { padding-top: 64px; }

  .breadcrumb {
    border-bottom: 1px solid var(--border);
    padding: 12px 40px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 12px;
  }
  .breadcrumb a { color: var(--fg-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--fg); }
  .arrow { color: var(--fg-subtle); }
  .current { color: var(--fg); font-weight: 500; }

  .content-wrap {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .thumb {
    height: 70vh;
    min-height: 480px;
    max-height: 780px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin: 40px 0;
    border-radius: 8px;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: 32px;
  }
  :global([data-theme="dark"]) .thumb {
    background: var(--bg-subtle) !important;
  }

  .content { max-width: 100%; padding-bottom: 96px; }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .content .overline { margin-bottom: 10px; }

  .role {
    font-size: 13px;
    font-weight: 500;
    color: var(--fg-subtle);
    margin-bottom: 32px;
    font-family: var(--font-body);
  }

  h1 {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--fg);
    margin-bottom: 24px;
    max-width: 760px;
  }

  .body {
    font-size: 17px;
    line-height: 1.7;
    color: var(--fg-muted);
    margin-bottom: 32px;
  }
  .body :global(p) { margin-bottom: 16px; max-width: 600px; }
  .body :global(p:last-child) { margin-bottom: 0; }

  .body :global(h2) {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 56px 0 16px;
    max-width: 100%;
  }
  .body :global(h3) {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--fg);
    margin: 32px 0 10px;
    max-width: 100%;
  }
  .body :global(h4) {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin: 28px 0 8px;
  }
  .body :global(ul), .body :global(ol) {
    padding-left: 20px;
    margin-bottom: 16px;
    max-width: 600px;
  }
  .body :global(li) {
    margin-bottom: 6px;
    line-height: 1.6;
  }
  .body :global(li:last-child) { margin-bottom: 0; }
  .body :global(strong) {
    font-weight: 600;
    color: var(--fg);
  }
  .body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }
  .body :global(img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 32px 0;
    border: 1px solid var(--border);
  }

  .body :global(.cs-split) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
    margin: 32px 0;
  }
  .body :global(.cs-split-body) {
    font-size: 17px;
    line-height: 1.7;
    color: var(--fg-muted);
  }
  .body :global(.cs-split-body p) { margin-bottom: 16px; }
  .body :global(.cs-split-body ul) { padding-left: 20px; }
  .body :global(.cs-split-body li) { margin-bottom: 6px; }
  .body :global(.cs-split-image img) {
    width: 100%;
    height: auto;
    border-radius: 8px 8px 0 0;
    border: 1px solid var(--border);
    border-bottom: none;
    margin: 0;
    display: block;
  }
  .body :global(.cs-split-image figure) {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .body :global(.cs-split-image figure img) {
    border-radius: 0;
    border: none;
    border-bottom: 1px solid var(--border);
  }
  .body :global(figcaption) {
    font-size: 12px;
    color: var(--fg-subtle);
    padding: 8px 12px;
    background: var(--bg-muted);
    line-height: 1.4;
  }
  .body :global(.cs-image-pair) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .body :global(.cs-image-pair figure) {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .body :global(.cs-image-pair img) {
    width: 100%;
    height: auto;
    border-radius: 0;
    border: none;
    border-bottom: 1px solid var(--border);
    margin: 0;
    display: block;
  }

  @media (max-width: 640px) {
    .body :global(.cs-split) { grid-template-columns: 1fr; }
    .body :global(.cs-image-pair) { grid-template-columns: 1fr 1fr; }
  }

  .outcomes {
    max-width: 100%;
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 24px 28px;
    margin-bottom: 36px;
  }
  .metrics { display: flex; flex-direction: column; gap: 10px; }
  .metric { display: flex; align-items: center; gap: 12px; }
  .metric-val {
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 500;
    color: var(--accent);
  }
  .metric-label { font-size: 14px; color: var(--fg-muted); }

  .actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* Two-column text layout */
  .body :global(.cs-columns) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin: 24px 0 32px;
  }
  .body :global(.cs-col-label) {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin-bottom: 12px !important;
    max-width: 100% !important;
  }
  .body :global(.cs-columns ul) {
    padding-left: 16px;
    margin: 0;
    max-width: 100%;
  }
  .body :global(.cs-columns li) { margin-bottom: 8px; font-size: 15px; }

  /* Featured final design */
  .body :global(.cs-featured) {
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin: 24px 0;
  }
  .body :global(.cs-featured img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    border: none;
    border-bottom: 1px solid var(--border);
    margin: 0;
  }
  .body :global(.cs-featured-body) {
    padding: 20px 24px;
  }
  .body :global(.cs-featured-body ul) {
    padding-left: 16px;
    margin: 0;
    max-width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px 24px;
  }
  .body :global(.cs-featured-body li) { font-size: 14px; margin-bottom: 4px; }

  @media (max-width: 640px) {
    .body :global(.cs-columns) { grid-template-columns: 1fr; }
    .body :global(.cs-featured-body ul) { grid-template-columns: 1fr; }
  }

  /* Carousel */
  .body :global(.cs-carousel) {
    margin: 32px 0;
  }
  .body :global(.cs-carousel-track-wrap) {
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-muted);
  }
  .body :global(.cs-carousel-track) {
    display: flex;
    transition: transform 0.35s ease;
    align-items: stretch;
  }
  .body :global(.cs-carousel-slide) {
    min-width: 100%;
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
  }
  .body :global(.cs-carousel-slide img) {
    width: 100%;
    height: 480px;
    object-fit: cover;
    object-position: top;
    display: block;
    border-radius: 0;
    border: none;
    margin: 0 !important;
  }

  /* Panning carousel — JS controls object-position; mouse overrides auto-pan */
  .body :global(.cs-carousel--pan .cs-carousel-slide img) {
    object-position: center 0%;
  }
  .body :global(.cs-carousel--pan .cs-carousel-track-wrap) {
    cursor: ns-resize;
  }

  @media (max-width: 640px) {
    .body :global(.cs-carousel-slide img) {
      height: auto;
      max-height: 280px;
      object-fit: contain;
      background: var(--bg-muted);
    }
  }
  .body :global(.cs-carousel-caption) {
    padding: 16px 20px;
    background: var(--bg-muted);
    border-top: 1px solid var(--border);
    flex: 1;
  }
  .body :global(.cs-carousel-caption strong) {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 4px;
  }
  .body :global(.cs-carousel-caption p) {
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0;
    max-width: 100%;
  }
  .body :global(.cs-carousel-nav) {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
  }
  .body :global(.cs-carousel-btn) {
    background: var(--bg-surface);
    border: 1px solid var(--border-strong);
    color: var(--fg);
    width: 36px;
    height: 36px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .body :global(.cs-carousel-btn:hover) { background: var(--bg-muted); }
  .body :global(.cs-carousel-btn:disabled) { opacity: 0.35; cursor: default; }
  .body :global(.cs-carousel-counter) {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-subtle);
  }

  /* Auto-scroll toggle */
  .body :global(.cs-pan-toggle) {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-left: auto;
    cursor: pointer;
    user-select: none;
  }
  .body :global(.cs-pan-toggle-input) { display: none; }
  .body :global(.cs-pan-toggle-track) {
    width: 30px;
    height: 17px;
    background: var(--border-strong);
    border-radius: 9px;
    position: relative;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .body :global(.cs-pan-toggle-track::after) {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--bg-surface);
    transition: transform 0.2s;
  }
  .body :global(.cs-pan-toggle-input:checked ~ .cs-pan-toggle-track) {
    background: var(--accent);
  }
  .body :global(.cs-pan-toggle-input:checked ~ .cs-pan-toggle-track::after) {
    transform: translateX(13px);
  }
  .body :global(.cs-pan-toggle-text) {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-subtle);
  }

  @media (max-width: 640px) {
    .breadcrumb { padding: 12px 20px; }
    .content-wrap { padding: 0 20px; }
    .thumb { height: 50vw; min-height: 260px; margin: 24px 0; }
    h1 { font-size: 28px; }
    .body :global(p), .body :global(ul), .body :global(ol) { max-width: 100%; }
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.88);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    cursor: zoom-out;
  }
  .lightbox.open {
    opacity: 1;
    pointer-events: all;
  }
  .lightbox img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
    cursor: default;
  }
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 28px;
    cursor: pointer;
    line-height: 1;
    padding: 4px 8px;
    transition: color 0.15s;
  }
  .lightbox-close:hover { color: #fff; }
  .body :global(img) { cursor: zoom-in; }
  .body :global(.cs-carousel--pan img) { cursor: ns-resize; }
</style>

<div class="lightbox" id="lightbox" aria-modal="true" role="dialog">
  <button class="lightbox-close" id="lightbox-close" aria-label="Close">×</button>
  <img id="lightbox-img" src="" alt="" />
</div>

<script>
  // Lightbox
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLImageElement>('.body img').forEach(img => {
    if (img.closest('.cs-carousel--pan')) return;
    img.addEventListener('click', () => openLightbox(img.src, img.alt));
  });

  lightbox.addEventListener('click', closeLightbox);
  lightboxImg.addEventListener('click', e => e.stopPropagation());
  document.getElementById('lightbox-close')!.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

  document.querySelectorAll<HTMLElement>('.cs-carousel').forEach(carousel => {
    const track = carousel.querySelector<HTMLElement>('.cs-carousel-track')!;
    const slides = carousel.querySelectorAll('.cs-carousel-slide');
    const prev = carousel.querySelector<HTMLButtonElement>('.cs-carousel-prev')!;
    const next = carousel.querySelector<HTMLButtonElement>('.cs-carousel-next')!;
    const counter = carousel.querySelector<HTMLElement>('.cs-carousel-counter')!;
    let current = 0;

    function go(n: number) {
      current = Math.max(0, Math.min(n, slides.length - 1));
      track.style.transform = `translateX(-${current * 100}%)`;
      counter.textContent = `${current + 1} / ${slides.length}`;
      prev.disabled = current === 0;
      next.disabled = current === slides.length - 1;
    }

    prev.addEventListener('click', () => go(current - 1));
    next.addEventListener('click', () => go(current + 1));
    go(0);
  });

  // Panning carousels — off by default; toggle enables auto-pan; mouse always controls on hover
  document.querySelectorAll<HTMLElement>('.cs-carousel--pan').forEach(carousel => {
    const wrap = carousel.querySelector<HTMLElement>('.cs-carousel-track-wrap')!;
    const imgs = carousel.querySelectorAll<HTMLImageElement>('.cs-carousel-slide img');
    const nav = carousel.querySelector<HTMLElement>('.cs-carousel-nav')!;
    let pos = 0;
    let dir = 1;
    let hovered = false;
    let autoPan = false;

    // Inject toggle switch into nav
    const label = document.createElement('label');
    label.className = 'cs-pan-toggle';
    label.innerHTML = `<input type="checkbox" class="cs-pan-toggle-input" /><span class="cs-pan-toggle-track"></span><span class="cs-pan-toggle-text">Auto-scroll</span>`;
    nav.appendChild(label);
    const input = label.querySelector<HTMLInputElement>('.cs-pan-toggle-input')!;
    input.addEventListener('change', () => { autoPan = input.checked; });

    function setPos(p: number) {
      pos = Math.max(0, Math.min(100, p));
      imgs.forEach(img => { img.style.objectPosition = `center ${pos}%`; });
    }

    (function tick() {
      if (autoPan && !hovered) {
        if (pos >= 100) dir = -1;
        if (pos <= 0) dir = 1;
        setPos(pos + dir * 0.04);
      }
      requestAnimationFrame(tick);
    })();

    wrap.addEventListener('mousemove', (e: MouseEvent) => {
      hovered = true;
      const r = wrap.getBoundingClientRect();
      setPos(((e.clientY - r.top) / r.height) * 100);
    });

    wrap.addEventListener('mouseleave', () => { hovered = false; });

    wrap.addEventListener('wheel', (e: WheelEvent) => {
      e.preventDefault();
      setPos(pos + e.deltaY * 0.05);
    }, { passive: false });
  });
</script>
