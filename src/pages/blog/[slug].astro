---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { data: d } = post;
const { Content } = await post.render();
---
<Base title={d.title} description={d.description}>
  <Nav />
  <main>
    <div class="breadcrumb">
      <a href="/blog">Blog</a>
      <span class="arrow">→</span>
      <span class="current">{d.title}</span>
    </div>

    <article>
      <header>
        <time datetime={d.date.toISOString()}>
          {d.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1>{d.title}</h1>
        {d.description && <p class="description">{d.description}</p>}
      </header>

      <div class="body">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</Base>

<style>
  main { padding-top: 64px; }

  .breadcrumb {
    border-bottom: 1px solid var(--border);
    padding: 12px 40px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 12px;
  }
  .breadcrumb a { color: var(--fg-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--fg); }
  .arrow { color: var(--fg-subtle); }
  .current { color: var(--fg); font-weight: 500; }

  article {
    max-width: 680px;
    margin: 0 auto;
    padding: 64px 40px 96px;
  }

  header { margin-bottom: 48px; }
  header time {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-subtle);
    display: block;
    margin-bottom: 16px;
  }
  header h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--fg);
    margin-bottom: 16px;
  }
  .description {
    font-size: 18px;
    line-height: 1.6;
    color: var(--fg-muted);
  }

  .body { font-size: 17px; line-height: 1.75; color: var(--fg-muted); }
  .body :global(h2) {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 48px 0 16px;
  }
  .body :global(h3) {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--fg);
    margin: 36px 0 12px;
  }
  .body :global(p) { margin-bottom: 24px; }
  .body :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .body :global(ul), .body :global(ol) { padding-left: 24px; margin-bottom: 24px; }
  .body :global(li) { margin-bottom: 8px; }
  .body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 20px;
    margin: 32px 0;
    color: var(--fg-muted);
    font-style: italic;
  }
  .body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg-muted);
    padding: 2px 6px;
    border-radius: 3px;
  }
  .body :global(pre) {
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 20px;
    overflow-x: auto;
    margin-bottom: 24px;
  }
  .body :global(pre code) { background: none; padding: 0; }
  .body :global(img) { max-width: 100%; border-radius: 6px; margin: 8px 0; }
</style>
