---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}
const { title = 'Paul Amsbary', description = 'UX Design · Research · Leadership', noindex = false } = Astro.props;
const shouldNoIndex = noindex || !!import.meta.env.BASE_PATH;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {shouldNoIndex && <meta name="robots" content="noindex, nofollow" />}
  <title>{title === 'Paul Amsbary' ? title : `${title} — Paul Amsbary`}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" />
<!-- Anti-FOUC: apply saved theme before first paint -->
  <script is:inline>
    (function() {
      const t = localStorage.getItem('pa-theme') || 'light';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
  <slot />
</body>
</html>
