---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Paul Amsbary', description = 'UX Design · Research · Leadership' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'Paul Amsbary' ? title : `${title} — Paul Amsbary`}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" />
<!-- Anti-FOUC: apply saved theme before first paint -->
  <script is:inline>
    (function() {
      const t = localStorage.getItem('pa-theme') || 'light';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
  <slot />
</body>

<!-- Password gate -->
<div id="pg-overlay" style="display:none">
  <div id="pg-box">
    <p id="pg-logo">PA</p>
    <h2 id="pg-heading">This portfolio is password protected.</h2>
    <p id="pg-sub">Enter the password to continue, or request access below.</p>
    <div id="pg-form-wrap">
      <input id="pg-input" type="password" placeholder="Password" autocomplete="current-password" />
      <button id="pg-submit">Enter</button>
      <p id="pg-error" style="display:none">Incorrect password. Try again or request access.</p>
    </div>
    <button id="pg-request-toggle">Request access →</button>
    <div id="pg-request-form" style="display:none">
      <p id="pg-request-sub">Send a request and I'll reply with the password.</p>
      <form id="pg-form" action="https://formspree.io/f/mkokyzon" method="POST">
        <input type="hidden" name="_subject" value="Portfolio access request" />
        <input name="name" type="text" placeholder="Your name" required />
        <input name="email" type="email" placeholder="Your email" required />
        <textarea name="message" placeholder="Brief note (optional)" rows="3"></textarea>
        <button type="submit">Send request</button>
      </form>
      <p id="pg-sent" style="display:none">Request sent — I'll be in touch.</p>
    </div>
  </div>
</div>

<style>
  #pg-overlay {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: var(--bg, #fff);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    font-family: var(--font-body, 'DM Sans', sans-serif);
  }
  #pg-box {
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  #pg-logo {
    font-family: var(--font-mono, monospace);
    font-size: 13px;
    font-weight: 500;
    color: var(--fg-subtle, #999);
    margin: 0 0 8px;
  }
  #pg-heading {
    font-family: var(--font-display, 'Syne', sans-serif);
    font-size: 22px;
    font-weight: 700;
    color: var(--fg, #111);
    margin: 0;
    line-height: 1.2;
  }
  #pg-sub, #pg-request-sub {
    font-size: 14px;
    color: var(--fg-muted, #666);
    margin: 0;
    line-height: 1.5;
  }
  #pg-form-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 4px;
  }
  #pg-overlay input,
  #pg-overlay textarea {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--border, #ddd);
    border-radius: 6px;
    font-size: 14px;
    font-family: inherit;
    background: var(--bg-surface, #fff);
    color: var(--fg, #111);
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.15s;
  }
  #pg-overlay input:focus,
  #pg-overlay textarea:focus {
    border-color: var(--accent, #C07A3A);
  }
  #pg-overlay textarea { resize: vertical; }
  #pg-overlay button[type=submit],
  #pg-submit {
    padding: 10px 20px;
    background: var(--fg, #111);
    color: var(--bg, #fff);
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.15s;
    align-self: flex-start;
  }
  #pg-overlay button[type=submit]:hover,
  #pg-submit:hover { opacity: 0.75; }
  #pg-error {
    font-size: 13px;
    color: #c0392b;
    margin: 0;
  }
  #pg-request-toggle {
    background: none;
    border: none;
    padding: 0;
    font-size: 13px;
    color: var(--accent, #C07A3A);
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    margin-top: 4px;
  }
  #pg-request-toggle:hover { text-decoration: underline; }
  #pg-request-form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 1px solid var(--border, #ddd);
    padding-top: 16px;
    margin-top: 4px;
  }
  #pg-request-form form {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  #pg-sent {
    font-size: 14px;
    color: var(--fg-muted, #666);
    margin: 0;
  }
</style>

<script is:inline>
  (function () {
    const HASH = '8f40d29c6591983ace8fd1bf3b517cbe7290e2fc26d2cab47739510b40b75ea7';
    const KEY  = 'pa-auth';

    async function sha256(str) {
      const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
      return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
    }

    const overlay = document.getElementById('pg-overlay');

    if (localStorage.getItem(KEY) === '1') return; // already authenticated

    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    const input   = document.getElementById('pg-input');
    const submit  = document.getElementById('pg-submit');
    const error   = document.getElementById('pg-error');

    async function attempt() {
      const h = await sha256(input.value.trim());
      if (h === HASH) {
        localStorage.setItem(KEY, '1');
        overlay.style.display = 'none';
        document.body.style.overflow = '';
      } else {
        error.style.display = 'block';
        input.value = '';
        input.focus();
      }
    }

    submit.addEventListener('click', attempt);
    input.addEventListener('keydown', e => { if (e.key === 'Enter') attempt(); });

    // Request access toggle
    const toggle      = document.getElementById('pg-request-toggle');
    const requestForm = document.getElementById('pg-request-form');
    toggle.addEventListener('click', () => {
      const open = requestForm.style.display !== 'none';
      requestForm.style.display = open ? 'none' : 'flex';
      toggle.textContent = open ? 'Request access →' : 'Hide request form';
    });

    // Form submission
    const form  = document.getElementById('pg-form');
    const sent  = document.getElementById('pg-sent');
    form.addEventListener('submit', async e => {
      e.preventDefault();
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.style.display = 'none';
          sent.style.display = 'block';
        }
      } catch (_) {}
    });
  })();
</script>
</html>
